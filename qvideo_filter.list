# 腾讯视频广告域名分流（不依赖 MitM / 不依赖抓包）
# QX：分流 → 引用 → 本文件，策略选 reject
#
# v4.9 实验：整域 reject i.video 后广告仍在 → 已从本列表移除
# 业务域靠 udp_drop + MitM 重写，不整域 reject

host-suffix, l.qq.com, reject
host, pgdt.gtimg.cn, reject
host-suffix, gdtimg.com, reject
host-suffix, gdt.qq.com, reject
host, sdkreport.e.qq.com, reject
host, info4.video.qq.com, reject
host, info6.video.qq.com, reject
host, otheve.beacon.qq.com, reject
host, splashqqlive.gtimg.com, reject
host-suffix, pangolin-sdk-toutiao.com, reject
host-suffix, pglstatp-toutiao.com, reject
host-suffix, iwan.qq.com, reject
host, iwan.video.qq.com, reject
# 开屏素材域（hostname 级；shiply-cdn 混业务不能整域 reject，靠丢弃 QUIC + 重写路径）
host-keyword, splashqqlive, reject
